    "test:odeon:gb": "playwright test --project=odeon-gb",
    "test:odeon:spain": "playwright test --project=odeon-spain",
    "test:odeon:italy": "playwright test --project=odeon-italy"
  },
  "keywords": ["playwright", "testing", "wikipedia"],
