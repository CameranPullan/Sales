      "noResults": ".mw-search-nonefound",
      "didYouMean": ".searchdidyoumean",
      "pagination": ".mw-search-pager"
    },
    "search": {
      "firstResult": ".mw-search-result:first-child .mw-search-result-heading a",
      "results": ".mw-search-results"
    },
    "specialPages": {
      "recentChanges": "#n-recentchanges",
      "randomArticle": "#n-randompage",
      "help": "#n-help",
      "aboutPage": "#n-aboutsite"
    }
