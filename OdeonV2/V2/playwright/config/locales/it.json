    "common": {
      "logo": "a.mw-logo",
      "mainNavigation": "#p-navigation",
      "footer": "#footer",
      "searchInput": "#searchInput",
      "searchButton": "#searchButton",
      "languageSelector": "#p-lang"
    },
    "homePage": {
      "logo": "a.mw-logo",
      "featuredArticle": "[id*=\"vetrina\"], [id*=\"In_evidenza\"]",
