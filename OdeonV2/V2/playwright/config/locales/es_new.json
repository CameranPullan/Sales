{
  "baseUrl": "https://es.wikipedia.org",
  "language": "Spanish",
  "selectors": {
    "homePage": {
      "logo": ".mw-wiki-logo",
      "featuredArticle": "h2:has-text('Cherish'), h2 a[href*='/wiki/'], .mp-topbanner",
      "featuredArticleLink": "h2 a[href*='/wiki/']:first, p a[href*='/wiki/']:first",
      "searchBox": "#searchInput",
      "searchButton": "#searchButton",
      "randomArticle": "#n-randompage a",
      "mainPageLink": "#ca-nstab-main a"
    },
    "searchPage": {
      "searchResults": ".mw-search-result-heading",
      "firstResult": ".mw-search-result-heading:first-child a",
      "noResults": ".mw-search-nonefound",
      "didYouMean": ".searchdidyoumean"
    },
    "articlePage": {
      "title": "#firstHeading",
      "content": "#mw-content-text",
      "infobox": ".infobox",
      "categories": "#mw-normal-catlinks"
    }
  },
  "translations": {
